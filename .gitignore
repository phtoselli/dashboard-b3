# ===========================================
# B3 Dividendos Analyzer - Git Ignore
# ===========================================

# -------------------------------------------
# Dependencies
# -------------------------------------------
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
bun.lockb

# -------------------------------------------
# Testing
# -------------------------------------------
/coverage
*.lcov
.nyc_output/

# -------------------------------------------
# Next.js
# -------------------------------------------
/.next/
/out/
.next/
next-env.d.ts

# -------------------------------------------
# Production
# -------------------------------------------
/build
/dist
*.tsbuildinfo

# -------------------------------------------
# Environment Variables
# -------------------------------------------
# Ignore all .env files except .env.example
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# -------------------------------------------
# Database
# -------------------------------------------
*.db
*.db-journal
*.sqlite
*.sqlite3
/db/*.db
/db/*.db-journal
prisma/*.db
prisma/*.db-journal

# -------------------------------------------
# Logs
# -------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
bun-debug.log*
dev.log
server.log
logs/
*.log

# -------------------------------------------
# IDEs and Editors
# -------------------------------------------
# VSCode
.vscode/
*.code-workspace

# JetBrains IDEs (IntelliJ, WebStorm, etc.)
.idea/
*.iml

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# -------------------------------------------
# Operating System Files
# -------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory

# -------------------------------------------
# Vercel
# -------------------------------------------
.vercel/

# -------------------------------------------
# TypeScript
# -------------------------------------------
*.tsbuildinfo

# -------------------------------------------
# Miscellaneous
# -------------------------------------------
*.pem
*.p12
*.pfx
*.key
*.crt
*.cer

# -------------------------------------------
# Project Specific
# -------------------------------------------
local-*
.claude/
.z-ai-config/
test/
prompt/
/skills/
upload/
download/
examples/
mini-services/

# -------------------------------------------
# Cache
# -------------------------------------------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# -------------------------------------------
# Temporary Files
# -------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# -------------------------------------------
# Secrets and Credentials
# -------------------------------------------
secrets/
credentials/
*.secret
*.credentials
