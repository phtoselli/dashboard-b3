# ===========================================
# B3 Dividendos Analyzer - Variáveis de Ambiente para Produção (Vercel)
# ===========================================
# Configure estas variáveis no Dashboard da Vercel:
# Settings > Environment Variables

# -------------------------------------------
# BANCO DE DADOS (PostgreSQL - OBRIGATÓRIO)
# -------------------------------------------
# Opções recomendadas para Vercel:
# 1. Vercel Postgres (mais simples)
# 2. Supabase (gratuito, feature-rich)
# 3. Neon (serverless PostgreSQL)
# 4. PlanetScale (MySQL, alternativa)
# 5. Railway (PostgreSQL gerenciado)

# URL de conexão com o banco (pooler para serverless)
DATABASE_URL="postgres://usuario:senha@host:5432/database?pgbouncer=true&connect_timeout=15"

# URL direta para migrações (sem pooler)
DIRECT_DATABASE_URL="postgres://usuario:senha@host:5432/database?connect_timeout=15"

# -------------------------------------------
# Brapi.dev API (OBRIGATÓRIO)
# -------------------------------------------
# Obtenha sua chave gratuita em: https://brapi.dev/
# Plano gratuito: 100 requisições/dia
# Plano pago: requisições ilimitadas
BRAPI_API_KEY="sua_api_key_aqui"

# -------------------------------------------
# NextAuth.js (OBRIGATÓRIO)
# -------------------------------------------
# Chave secreta para criptografia de sessões
# Gere uma com: openssl rand -base64 32
NEXTAUTH_SECRET="gere_uma_chave_secreta_forte_aqui"

# URL base da aplicação em produção
# IMPORTANTE: Deve ser a URL final do seu deploy
# Exemplo: https://b3-dividendos.vercel.app
NEXTAUTH_URL="https://seu-dominio.vercel.app"

# -------------------------------------------
# CONFIGURAÇÕES OPCIONAIS
# -------------------------------------------

# Ambiente (automático na Vercel)
# NODE_ENV="production"

# URL do site para meta tags
NEXT_PUBLIC_SITE_URL="https://seu-dominio.vercel.app"

# Nome do site
NEXT_PUBLIC_SITE_NAME="B3 Dividendos Analyzer"

# Descrição do site
NEXT_PUBLIC_SITE_DESCRIPTION="Analise as melhores ações pagadoras de dividendos da B3"

# -------------------------------------------
# ANALYTICS (OPCIONAL)
# -------------------------------------------
# Google Analytics 4
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Vercel Analytics (habilitar no dashboard)
# NEXT_PUBLIC_VERCEL_ANALYTICS=true

# -------------------------------------------
# MONITORAMENTO (OPCIONAL)
# -------------------------------------------
# Sentry para monitoramento de erros
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@sentry.io/xxx"
# SENTRY_AUTH_TOKEN="xxx"
# SENTRY_ORG="sua-org"
# SENTRY_PROJECT="seu-projeto"

# -------------------------------------------
# INTEGRAÇÕES FUTURAS (OPCIONAL)
# -------------------------------------------
# Discord Webhook para notificações
# DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/xxx"

# Telegram Bot
# TELEGRAM_BOT_TOKEN="xxx"
# TELEGRAM_CHAT_ID="xxx"

# Email (Resend, SendGrid, etc.)
# EMAIL_FROM="noreply@seudominio.com"
# RESEND_API_KEY="re_xxx"
