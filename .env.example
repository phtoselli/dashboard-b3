# ===========================================
# B3 Dividendos Analyzer - Environment Variables
# ===========================================
# Copie este arquivo para .env e preencha com seus valores reais
# cp .env.example .env

# -------------------------------------------
# BANCO DE DADOS (DESENVOLVIMENTO LOCAL)
# -------------------------------------------
# Para desenvolvimento local com SQLite:
DATABASE_URL="file:./db/custom.db"
DIRECT_DATABASE_URL="file:./db/custom.db"

# Para PostgreSQL local (Docker, etc):
# DATABASE_URL="postgres://postgres:postgres@localhost:5432/b3dividendos?connect_timeout=15"
# DIRECT_DATABASE_URL="postgres://postgres:postgres@localhost:5432/b3dividendos?connect_timeout=15"

# -------------------------------------------
# Brapi.dev API
# -------------------------------------------
# Chave de API para obter cotações em tempo real da B3
# Obtenha sua chave gratuita em: https://brapi.dev/
# Plano gratuito: 100 requisições/dia
# Plano pago: requisições ilimitadas
BRAPI_API_KEY="sua_api_key_aqui"

# -------------------------------------------
# NextAuth.js (Autenticação)
# -------------------------------------------
# Chave secreta para criptografia de sessões
# Gere uma com: openssl rand -base64 32
NEXTAUTH_SECRET="sua_chave_secreta_aqui"

# URL base da aplicação
NEXTAUTH_URL="http://localhost:3000"

# -------------------------------------------
# CONFIGURAÇÕES OPCIONAIS
# -------------------------------------------
# Ambiente de execução
# NODE_ENV="development"

# Porta do servidor (padrão: 3000)
# PORT="3000"

# URL do site para meta tags
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Nome do site
NEXT_PUBLIC_SITE_NAME="B3 Dividendos Analyzer"

# Descrição do site
NEXT_PUBLIC_SITE_DESCRIPTION="Analise as melhores ações pagadoras de dividendos da B3"

# -------------------------------------------
# PARA PRODUÇÃO (VERCEL)
# -------------------------------------------
# Veja o arquivo .env.production.example para todas as variáveis
# necessárias para deploy em produção na Vercel

# Banco de dados PostgreSQL (OBRIGATÓRIO em produção)
# DATABASE_URL="postgres://..."
# DIRECT_DATABASE_URL="postgres://..."

# URL de produção
# NEXTAUTH_URL="https://seu-dominio.vercel.app"
